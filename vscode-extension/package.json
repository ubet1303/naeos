{
  "name": "naeos-neir",
  "displayName": "NAEOS NEIR Support",
  "description": "Language support for NAEOS NEIR specifications",
  "version": "0.1.0",
  "publisher": "naeos-foundation",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Programming Languages", "Formatters"],
  "activationEvents": [
    "onLanguage:yaml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "naeos-spec",
        "aliases": ["NAEOS Specification", "naeos-spec"],
        "extensions": [".naeos.yaml", ".naeos.yml", ".neir.yaml"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "naeos-spec",
        "scopeName": "source.naeos-spec",
        "path": "./syntaxes/naeos-spec.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "naeos.validate",
        "title": "NEIR: Validate Specification"
      },
      {
        "command": "naeos.suggest",
        "title": "NEIR: Get AI Suggestions"
      },
      {
        "command": "naeos.diff",
        "title": "NEIR: Show Diff"
      }
    ],
    "configuration": {
      "title": "NAEOS NEIR",
      "properties": {
        "naeos.executablePath": {
          "type": "string",
          "default": "naeos",
          "description": "Path to the naeos executable"
        },
        "naeos.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable LSP server for real-time validation"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.3.0",
    "typescript": "^5.3.0"
  }
}
