      {"name": "storage", "path": "./internal/storage", "description": "Data access layer", "dependencies": ["core"]},
      {"name": "notifications", "path": "./internal/notifications", "description": "Email and push notification service", "dependencies": ["core"]}
    ],
    "services": [
      {"name": "api-gateway", "kind": "http", "port": 8080, "description": "REST API gateway"},
      {"name": "worker", "kind": "worker", "port": 0, "description": "Background job processor"}
    ],
    "architecture": {
      "pattern": "hexagonal",
      "principles": ["ports and adapters", "dependency inversion", "single responsibility"]
    },
    "security": {
      "authentication": "jwt",
      "authorization": "rbac",
      "roles": ["admin", "user", "viewer"],
      "encryption": true
    },
    "deployment": {
      "strategy": "rolling",
      "environments": ["development", "staging", "production"]
    },
    "testing": {
      "strategy": "unit-integration",
      "coverage": "80%",
      "frameworks": ["testing", "testify"]
    },
    "tags": ["web", "multi-tenant", "subscription"]
