    "id": "saas",
    "name": "SaaS Application",
    "description": "Multi-tenant Software-as-a-Service web application with authentication, billing, and API gateway",
    "industry": "technology",
    "version": "1.0.0",
    "modules": [
      {"name": "auth", "path": "./internal/auth", "description": "Authentication and authorization module", "dependencies": ["core"]},
      {"name": "billing", "path": "./internal/billing", "description": "Subscription and payment management", "dependencies": ["core", "auth"]},
