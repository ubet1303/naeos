---
import BaseLayout from "../layouts/BaseLayout.astro";
import { useTranslations } from "../i18n/utils";

const lang = "en";
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  lang={lang}
  title={t("404.title")}
  description={t("404.desc")}
>
  <div class="min-h-screen flex flex-col items-center justify-center text-center px-4">
    <div class="text-8xl font-extrabold gradient-text mb-4">404</div>
    <h1 class="text-2xl font-bold mb-2">{t("404.title")}</h1>
    <p class="text-[#888] mb-8 max-w-md">{t("404.desc")}</p>
    <a
      href={base || "/"}
      class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[#00ff88] text-[#0a0a0a] font-semibold hover:bg-[#00cc6a] transition-all duration-200"
    >
      {t("404.home")}
    </a>
  </div>
</BaseLayout>
