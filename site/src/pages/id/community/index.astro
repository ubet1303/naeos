---
import PageLayout from "../../../layouts/PageLayout.astro";

const lang = "id";

const channels = [
  {
    name: "GitHub Discussions",
    icon: "💬",
    desc: "Tanya, bagikan ide, dan diskusikan fitur dengan komunitas.",
    href: "https://github.com/NAEOS-foundation/naeos/discussions",
    cta: "Gabung Diskusi",
  },
  {
    name: "Issue Tracker",
    icon: "🐛",
    desc: "Laporkan bug, minta fitur, atau pantau perkembangan proyek.",
    href: "https://github.com/NAEOS-foundation/naeos/issues",
    cta: "Buka Issues",
  },
  {
    name: "Panduan Kontribusi",
    icon: "📝",
    desc: "Pelajari cara berkontribusi kode, dokumentasi, atau spesifikasi.",
    href: "https://github.com/NAEOS-foundation/naeos/blob/main/CONTRIBUTING.md",
    cta: "Baca Panduan",
  },
  {
    name: "GitHub Sponsors",
    icon: "❤️",
    desc: "Dukung proyek secara finansial dan bantu keberlanjutan pengembangan.",
    href: "https://github.com/sponsors/NAEOS-foundation",
    cta: "Sponsor",
  },
  {
    name: "Security Advisories",
    icon: "🛡️",
    desc: "Laporkan kerentanan keamanan secara bertanggung jawab.",
    href: "https://github.com/NAEOS-foundation/naeos/security/advisories",
    cta: "Lapor",
  },
  {
    name: "Kode Etik",
    icon: "🤝",
    desc: "Standar dan harapan komunitas untuk semua peserta.",
    href: "https://github.com/NAEOS-foundation/naeos/blob/main/CODE_OF_CONDUCT.md",
    cta: "Baca",
  },
];

const stats = [
  { label: "Commits", value: "2000+" },
  { label: "Kontributor", value: "10+" },
  { label: "Spesifikasi", value: "56" },
  { label: "Perintah CLI", value: "35+" },
  { label: "Bahasa", value: "5" },
  { label: "Adapter AI", value: "6" },
];
---

<PageLayout
  lang={lang}
  title="Komunitas"
  description="Bergabunglah dengan komunitas NAEOS — berkontribusi, berdiskusi, laporkan issue, dan bantu membentuk masa depan engineering berbasis spesifikasi."
>
  <div slot="header">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
      <span class="gradient-text">Komunitas</span>
    </h1>
    <p class="text-lg text-[#888] mb-12 max-w-2xl">
      Bergabung dengan komunitas NAEOS. Semua diskusi, pengembangan, dan dukungan proyek terjadi di GitHub.
    </p>
  </div>

  <div class="container-main max-w-5xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {channels.map(c => (
        <a href={c.href} target="_blank" rel="noopener noreferrer" class="glass p-6 hover:border-[#00ff88]/30 transition-all duration-300 group">
          <span class="text-3xl block mb-4">{c.icon}</span>
          <h2 class="text-lg font-bold mb-2 group-hover:text-[#00ff88] transition-colors">{c.name}</h2>
          <p class="text-sm text-[#888] mb-4 leading-relaxed">{c.desc}</p>
          <span class="text-xs text-[#00ff88] font-medium">{c.cta} →</span>
        </a>
      ))}
    </div>

    <div class="glass p-8 mb-12">
      <h2 class="text-xl font-bold mb-6 text-center">Statistik Proyek</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-2xl font-bold text-[#00ff88] mb-1">{s.value}</div>
            <div class="text-xs text-[#666]">{s.label}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="glass p-8 text-center">
      <h2 class="text-xl font-bold mb-4">Cara Berkontribusi</h2>
      <div class="max-w-2xl mx-auto text-left space-y-4 mb-8">
        {[
          { step: "1", title: "Baca Panduan Kontribusi", desc: "Pelajari konvensi, proses PR, dan standar coding kami." },
          { step: "2", title: "Temukan Issue", desc: "Cari issue berlabel good-first-issue atau help-wanted. Tanya sebelum memulai." },
          { step: "3", title: "Fork & Branch", desc: "Fork repo, buat branch fitur, dan lakukan perubahan." },
          { step: "4", title: "Kirim Pull Request", desc: "Buka PR dengan deskripsi jelas tentang apa yang Anda ubah dan mengapa." },
        ].map(item => (
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[#00ff88] text-[#0a0a0a] text-sm font-bold flex items-center justify-center shrink-0">{item.step}</div>
            <div>
              <h3 class="font-semibold text-sm">{item.title}</h3>
              <p class="text-xs text-[#888]">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <a href="https://github.com/NAEOS-foundation/naeos/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[#00ff88] text-[#0a0a0a] font-semibold hover:bg-[#00cc6a] transition-colors">
        Baca Panduan Kontribusi ↗
      </a>
    </div>
  </div>
</PageLayout>
