---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Hero from "../../components/Hero.astro";
import Features from "../../components/Features.astro";
import AnimatedPipeline from "../../components/AnimatedPipeline.astro";
import QuickStart from "../../components/QuickStart.astro";
import MultiLang from "../../components/MultiLang.astro";
import AIAdapters from "../../components/AIAdapters.astro";
import Commands from "../../components/Commands.astro";
import GitHubStats from "../../components/GitHubStats.astro";
import Playground from "../../components/Playground.astro";
import Roadmap from "../../components/Roadmap.astro";
import CTA from "../../components/CTA.astro";

const lang = "id";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<BaseLayout
  lang={lang}
  title="Tentukan Sekali. Bangun di Mana Saja."
  description="NAEOS adalah platform engineering deklaratif yang mengubah spesifikasi menjadi sistem perangkat lunak berkualitas tinggi melalui pipeline yang konsisten, tervalidasi, dan dapat diperluas."
>
  <Header lang={lang} currentPath={Astro.url.pathname} />
  <main>
    <Hero lang={lang} />

    <section class="py-12 border-t border-[#333]">
      <div class="container-main">
        <div class="max-w-4xl mx-auto">
          <GitHubStats />
        </div>
      </div>
    </section>

    <section class="py-16 border-t border-[#333]">
      <div class="container-main">
        <div class="text-center mb-10">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Pipeline</h2>
          <p class="text-[#888] text-lg max-w-2xl mx-auto">Dari spesifikasi ke artefak — orkestrasi pipeline NAEOS</p>
        </div>
        <div class="max-w-4xl mx-auto">
          <AnimatedPipeline />
        </div>
      </div>
    </section>

    <Features lang={lang} />
    <QuickStart lang={lang} />
    <MultiLang lang={lang} />
    <AIAdapters lang={lang} />
    <Commands lang={lang} />

    <section class="py-20 border-t border-[#333]">
      <div class="container-main">
        <div class="text-center mb-10">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Playground Interaktif</h2>
          <p class="text-[#888] text-lg max-w-2xl mx-auto">Tulis spesifikasi dan lihat pipeline beraksi</p>
        </div>
        <div class="max-w-5xl mx-auto">
          <Playground />
        </div>
      </div>
    </section>

    <Roadmap lang={lang} />
    <CTA lang={lang} />
  </main>
  <Footer lang={lang} />
</BaseLayout>
