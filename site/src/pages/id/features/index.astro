---
import PageLayout from "../../../layouts/PageLayout.astro";
import FeatureDetail from "../../../components/FeatureDetail.astro";
import { featuresID } from "../../../content/features-en";

const lang = "id";
---

<PageLayout
  lang={lang}
  title="Fitur"
  description="Jelajahi semua fitur NAEOS — Pipeline Inti, Spec Language v2, Generasi Kode Multi-Bahasa, Integrasi AI, Marketplace, dan Tata Kelola."
>
  <div slot="header">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
      <span class="gradient-text">Fitur</span>
    </h1>
    <p class="text-lg text-[#888] mb-12 max-w-2xl">
      Runtime engineering lengkap untuk pengembangan berbasis spesifikasi. Setiap fitur dirancang untuk bekerja bersama secara mulus.
    </p>
  </div>

  <div class="container-main max-w-4xl mx-auto px-6">
    {featuresID.map(f => <FeatureDetail {...f} />)}
  </div>
</PageLayout>
