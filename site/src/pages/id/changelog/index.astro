---
import PageLayout from "../../../layouts/PageLayout.astro";

const lang = "id";

const releases = [
  { version: "2.1.0", date: "2026-07-20", highlight: "RBAC bootstrapping, workspace multi-tenant, API schema registry, 5 profil industri baru, enkripsi saat istirahat, CLI ekspor kepatuhan." },
  { version: "1.5.0", date: "2026-07-19", highlight: "Production hardening — race detector bersih, peningkatan cakupan tes." },
  { version: "1.4.0", date: "2026-07-19", highlight: "Prompt Library (NES-054), dashboard observabilitas data nyata, persistensi workflow manager, worker terdistribusi." },
  { version: "1.3.1", date: "2026-07-19", highlight: "999 isu lint teratasi menjadi 0 di 211 file — golangci-lint bersih." },
  { version: "1.3.0", date: "2026-07-16", highlight: "CLI --output json/yaml untuk 14 perintah, scan keamanan, 39 tes integrasi CLI baru." },
  { version: "1.2.0", date: "2026-07-15", highlight: "Lapisan database dengan PostgreSQL, MySQL, SQLite — connection pool, retry, health checks." },
  { version: "1.1.0", date: "2026-07-15", highlight: "Cakupan tes di 10 paket, perbaikan race WebSocket, migrasi interface{}→any." },
  { version: "1.0.0", date: "2026-07-14", highlight: "Rilis stabil — 65.4% cakupan tes, 32 tes endpoint API, penguatan keamanan." },
  { version: "0.9.0", date: "2026-07-13", highlight: "Logging terstruktur, RBAC, OAuth2, audit logging, GoReleaser, TUI interaktif." },
  { version: "0.8.0", date: "2026-07-13", highlight: "Sistem error bertipe, server WebSocket, fondasi MCP server." },
  { version: "0.7.0", date: "2026-07-13", highlight: "10 perintah CLI baru, event sourcing dengan snapshot agregat." },
  { version: "0.6.0", date: "2026-07-12", highlight: "Manajemen versi terpusat, fondasi workspace multi-tenant." },
  { version: "0.5.1", date: "2026-07-12", highlight: "Handler API terhubung penuh — specs, artifacts, MCP, pipeline status." },
  { version: "0.5.0", date: "2026-07-12", highlight: "Integrasi cloud — adapter AWS, GCP, Azure + ekspor Terraform." },
  { version: "0.4.0", date: "2026-07-11", highlight: "Peningkatan Spec Language v2, MCP server, migration engine, marketplace, benchmark." },
  { version: "0.3.0", date: "2026-07-11", highlight: "Spec Language v2 — interpolasi variabel, referensi silang, include file, fungsi kustom." },
  { version: "0.2.0", date: "2026-07-11", highlight: "Fondasi compiler — 6 adapter output AI, artifact store, profil industri." },
  { version: "0.1.0", date: "2026-01-01", highlight: "Struktur proyek awal — parser, model NEIR, pipeline, fondasi CLI." },
];
---

<PageLayout
  lang={lang}
  title="Riwayat Versi"
  description="Riwayat versi NAEOS — dari v0.1.0 hingga v2.1.0."
>
  <div slot="header">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
      <span class="gradient-text">Riwayat Versi</span>
    </h1>
    <p class="text-lg text-[#888] mb-12 max-w-2xl">
      Riwayat versi lengkap NAEOS. Dibangun dalam 7 bulan dari commit awal hingga v2.1.0 siap-produksi.
    </p>
  </div>

  <div class="container-main max-w-4xl mx-auto px-6">
    <div class="relative">
      <div class="absolute left-6 top-0 bottom-0 w-px bg-[#333]" />

      <div class="space-y-6">
        {releases.map(r => (
          <div class="relative flex gap-6">
            <div class="relative z-10 shrink-0">
              <div class="w-12 h-12 rounded-full bg-[#1a1a1a] border-2 border-[#00ff88] flex items-center justify-center text-xs font-bold text-[#00ff88]">
                v{r.version.split(".")[0]}
              </div>
            </div>
            <div class="flex-1 glass p-5">
              <div class="flex items-baseline gap-3 mb-2">
                <span class="text-lg font-bold font-mono text-[#00ff88]">v{r.version}</span>
                <span class="text-xs text-[#666]">{r.date}</span>
                {r.version === "2.1.0" && <span class="text-[10px] font-medium text-[#00ff88] px-2 py-0.5 rounded-full bg-[#00ff88]15 border border-[#00ff88]">Terbaru</span>}
                {r.version === "1.0.0" && <span class="text-[10px] font-medium text-[#ffaa00] px-2 py-0.5 rounded-full bg-[#ffaa00]15 border border-[#ffaa00]">Stabil</span>}
              </div>
              <p class="text-sm text-[#888] leading-relaxed">{r.highlight}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="glass p-6 mt-8 text-center">
      <p class="text-sm text-[#888]">
        Riwayat lengkap tersedia di <a href="https://github.com/NAEOS-foundation/naeos/blob/main/CHANGELOG.md" target="_blank" rel="noopener noreferrer" class="text-[#00ff88] hover:underline">GitHub</a>
      </p>
    </div>
  </div>
</PageLayout>
