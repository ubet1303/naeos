---
import PageLayout from "../../layouts/PageLayout.astro";

const lang = "en";

const stages = [
  { num: 1, name: "Parser", desc: "Reads YAML/JSON specification files. Handles <code>$include</code>, <code>$import</code>, variable interpolation (<code>${var}</code>), and environment variables (<code>$env{VAR}</code>).", color: "#00ff88" },
  { num: 2, name: "Normalizer", desc: "Normalizes data structures, applies type coercion, and resolves default values. Prepares a consistent data model for downstream stages.", color: "#66b3ff" },
  { num: 3, name: "Resolver", desc: "Resolves cross-references (<code>$ref{path}</code>), file imports (<code>$include</code>, <code>$import</code>), and custom functions (<code>$fn{name}</code>). Depth-limiting prevents circular imports.", color: "#7C3AED" },
  { num: 4, name: "NEIR Builder", desc: "Builds the NAEOS Engineering Intermediate Representation — a unified project model covering project, architecture, domain, modules, components, services, APIs, storage, infrastructure, security, AI, documentation, deployment, testing, and metadata.", color: "#00ff88" },
  { num: 5, name: "Validator", desc: "Comprehensive validation: circular dependency detection, port conflict resolution, module boundary enforcement, schema version checking.", color: "#ffaa00" },
  { num: 6, name: "Scheduler", desc: "DAG-based task scheduling. Analyzes dependency graph, determines parallel execution paths, and creates an optimized execution plan.", color: "#D97706" },
  { num: 7, name: "Generator", desc: "Multi-language code generation. Delegates to language-specific adapters (Go, TypeScript, Python, Java, Rust) and framework-specific renderers.", color: "#00ADD8" },
  { num: 8, name: "Renderer", desc: "Template rendering engine. Processes Go text/templates for README, Makefile, Dockerfile, docker-compose, .gitignore, and architecture docs.", color: "#4285F4" },
  { num: 9, name: "Reviewer", desc: "Policy evaluation and artifact review. Enforces governance rules, runs security analysis, and generates audit trail entries.", color: "#ff4444" },
];
---

<PageLayout
  lang={lang}
  title="Architecture"
  description="NAEOS transforms specifications into artifacts through a 9-stage pipeline — from parsing to policy review."
>
  <div slot="header">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
      <span class="gradient-text">Architecture</span>
    </h1>
    <p class="text-lg text-[#888] mb-4 max-w-2xl">
      NAEOS is built around a central pipeline that orchestrates the transformation from specification to deployable artifacts.
    </p>
  </div>

  <div class="container-main max-w-4xl mx-auto px-6">
    <div class="glass p-8 mb-12 text-center">
      <h2 class="text-lg font-semibold mb-4">Pipeline Overview</h2>
      <div class="flex flex-wrap items-center justify-center gap-1 text-sm font-mono">
        <span class="px-3 py-1.5 rounded bg-[#00ff88] text-[#0a0a0a] font-semibold">Input Spec</span>
        <span class="text-[#666]">→</span>
        <span class="px-3 py-1.5 rounded bg-[#1a1a1a] border border-[#333]">Parser</span>
        <span class="text-[#666]">→</span>
        <span class="px-3 py-1.5 rounded bg-[#1a1a1a] border border-[#333]">Normalizer</span>
        <span class="text-[#666]">→</span>
        <span class="px-3 py-1.5 rounded bg-[#1a1a1a] border border-[#333]">Resolver</span>
        <span class="text-[#666]">→</span>
        <span class="px-3 py-1.5 rounded bg-[#1a1a1a] border border-[#00ff88]">NEIR</span>
        <span class="text-[#666]">→</span>
        <span class="px-3 py-1.5 rounded bg-[#1a1a1a] border border-[#333]">Validator</span>
        <span class="text-[#666]">→</span>
        <span class="px-3 py-1.5 rounded bg-[#1a1a1a] border border-[#333]">Scheduler</span>
        <span class="text-[#666]">→</span>
        <span class="px-3 py-1.5 rounded bg-[#1a1a1a] border border-[#333]">Generator</span>
        <span class="text-[#666]">→</span>
        <span class="px-3 py-1.5 rounded bg-[#1a1a1a] border border-[#333]">Renderer</span>
        <span class="text-[#666]">→</span>
        <span class="px-3 py-1.5 rounded bg-[#1a1a1a] border border-[#333]">Reviewer</span>
        <span class="text-[#666]">→</span>
        <span class="px-3 py-1.5 rounded bg-[#00ff88] text-[#0a0a0a] font-semibold">Artifacts</span>
      </div>
    </div>

    <div class="mb-12">
      <h2 class="text-2xl font-bold mb-6">Pipeline Stages</h2>
      <div class="space-y-6">
        {stages.map(s => (
          <div class="glass p-6 flex gap-6">
            <div
              class="w-12 h-12 rounded-full flex items-center justify-center text-lg font-bold shrink-0"
              style={{ background: s.color + "22", color: s.color, border: "2px solid " + s.color }}
            >
              {s.num}
            </div>
            <div>
              <h3 class="text-lg font-semibold mb-2" style={{ color: s.color }}>{s.name}</h3>
              <p class="text-sm text-[#888] leading-relaxed" set:html={s.desc} />
            </div>
          </div>
        ))}
      </div>
    </div>

    <div class="glass p-8 mb-12">
      <h2 class="text-xl font-bold mb-4">Supporting Services</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="border border-[#333] rounded-lg p-4">
          <h3 class="font-semibold text-[#00ff88] mb-2">Kernel</h3>
          <p class="text-sm text-[#888]">Service registry, event bus (pub/sub), telemetry collection, and lifecycle management for all pipeline services.</p>
        </div>
        <div class="border border-[#333] rounded-lg p-4">
          <h3 class="font-semibold text-[#66b3ff] mb-2">Graph</h3>
          <p class="text-sm text-[#888]">Dependency DAG construction and analysis for determining parallel execution paths and topological ordering.</p>
        </div>
        <div class="border border-[#333] rounded-lg p-4">
          <h3 class="font-semibold text-[#7C3AED] mb-2">Registry</h3>
          <p class="text-sm text-[#888]">Component discovery and service registration for pipeline extensibility via plugins.</p>
        </div>
      </div>
    </div>

    <div class="glass p-8 mb-12">
      <h2 class="text-xl font-bold mb-4">NEIR Model</h2>
      <p class="text-sm text-[#888] mb-4">The NAEOS Engineering Intermediate Representation is the central model that represents the entire system. It is built by the pipeline and consumed by all downstream stages.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3 text-sm">
        {["Project", "Architecture", "Domain", "Modules", "Components", "Services", "APIs", "Storage", "Infrastructure", "Security", "AI", "Documentation", "Deployment", "Testing", "Metadata", "Generation"].map(f => (
          <div class="bg-[#0a0a0a] rounded px-3 py-2 text-[#e0e0e0] font-mono text-xs border border-[#333]">{f}</div>
        ))}
      </div>
    </div>
  </div>
</PageLayout>
