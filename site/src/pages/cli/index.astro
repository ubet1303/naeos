---
import PageLayout from "../../layouts/PageLayout.astro";
import { cliEN } from "../../content/cli-en";

const lang = "en";
---

<PageLayout
  lang={lang}
  title="CLI Reference"
  description="Complete command-line reference for NAEOS — 35+ commands organized by category."
>
  <div slot="header">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
      <span class="gradient-text">CLI Reference</span>
    </h1>
    <p class="text-lg text-[#888] mb-4 max-w-2xl">
      35+ commands organized into 4 categories. Every command supports <code class="text-[#00ff88]">--output json</code> and <code class="text-[#00ff88]">--output yaml</code> for machine-readable output.
    </p>
    <div class="glass p-4 mb-12 inline-flex items-center gap-2 text-sm font-mono">
      <span class="text-[#888]">Global:</span>
      <code class="text-[#66b3ff]">--verbose</code>
    </div>
  </div>

  <div class="container-main max-w-5xl mx-auto px-6">
    {cliEN.map(group => (
      <div class="mb-12">
        <div class="flex items-baseline gap-4 mb-6">
          <h2 class="text-2xl font-bold text-[#00ff88]">{group.group}</h2>
          <span class="text-sm text-[#666]">{group.description}</span>
        </div>

        <div class="space-y-4">
          {group.commands.map(cmd => (
            <div class="glass p-5">
              <div class="flex items-start justify-between gap-4 mb-3">
                <div>
                  <code class="text-base font-mono font-bold text-[#66b3ff]">{cmd.name}</code>
                  <p class="text-sm text-[#888] mt-1">{cmd.description}</p>
                </div>
              </div>

              <div class="bg-[#0a0a0a] rounded-lg px-4 py-2.5 mb-3 overflow-x-auto">
                <pre class="text-sm font-mono text-[#e0e0e0] whitespace-pre"><span class="text-[#00ff88]">$</span> {cmd.usage}</pre>
              </div>

              {cmd.flags && cmd.flags.length > 0 && (
                <div class="overflow-x-auto">
                  <table class="w-full text-xs">
                    <thead>
                      <tr class="text-[#666] uppercase tracking-wider">
                        <th class="text-left pb-2 pr-4">Flag</th>
                        <th class="text-left pb-2 pr-4">Type</th>
                        <th class="text-left pb-2 pr-4">Default</th>
                        <th class="text-left pb-2">Description</th>
                      </tr>
                    </thead>
                    <tbody class="text-[#888]">
                      {cmd.flags.map(f => (
                        <tr class="border-t border-[#333]">
                          <td class="py-2 pr-4"><code class="text-[#66b3ff]">{f.flag}</code>{f.short && <span class="text-[#666]"> ({f.short})</span>}</td>
                          <td class="py-2 pr-4 font-mono">{f.type}</td>
                          <td class="py-2 pr-4 font-mono text-[#666]">{f.default}</td>
                          <td class="py-2">{f.desc}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
            </div>
          ))}
        </div>
      </div>
    ))}

    <div class="glass p-6 mb-12 text-center">
      <p class="text-sm text-[#888]">
        Run <code class="text-[#00ff88] font-mono">naeos --help</code> for the full list of 35+ commands with detailed usage.
      </p>
    </div>
  </div>
</PageLayout>
