---
import PageLayout from "../../layouts/PageLayout.astro";

const lang = "en";

const methods = [
  {
    title: "Go Install",
    icon: "🔧",
    desc: "Install directly with Go (requires Go 1.25+)",
    steps: [
      { code: "go install github.com/NAEOS-foundation/naeos/cmd/naeos@latest", label: "Install" },
      { code: "naeos version", label: "Verify" },
    ],
    note: "Requires Go 1.25+ and $GOPATH/bin in your PATH.",
  },
  {
    title: "Docker",
    icon: "🐳",
    desc: "Pull and run with Docker (recommended for CI/CD)",
    steps: [
      { code: "docker pull ghcr.io/naeos-foundation/naeos:latest", label: "Pull image" },
      { code: `docker run --rm -v $(pwd):/workspace ghcr.io/naeos-foundation/naeos:latest \\
  naeos run --config /workspace/config.yaml --input-file /workspace/spec.yaml`, label: "Run pipeline" },
    ],
    note: "Mount your working directory to /workspace for spec access.",
  },
  {
    title: "Build from Source",
    icon: "📦",
    desc: "Clone and build the latest version",
    steps: [
      { code: "git clone https://github.com/NAEOS-foundation/naeos.git", label: "Clone" },
      { code: "cd naeos && go build ./cmd/naeos/", label: "Build" },
      { code: "./naeos version", label: "Verify" },
    ],
    note: "Builds the binary in the current directory. Move it to your PATH: sudo mv naeos /usr/local/bin/",
  },
  {
    title: "Binary Release",
    icon: "⬇️",
    desc: "Download pre-built binary from GitHub Releases",
    steps: [
      { code: `# Linux / macOS (amd64)
curl -L https://github.com/NAEOS-foundation/naeos/releases/latest/download/naeos-linux-amd64.tar.gz | tar xz
sudo mv naeos /usr/local/bin/`, label: "Linux" },
      { code: `# macOS (Apple Silicon)
curl -L https://github.com/NAEOS-foundation/naeos/releases/latest/download/naeos-darwin-arm64.tar.gz | tar xz
sudo mv naeos /usr/local/bin/`, label: "macOS (ARM)" },
    ],
    note: "See the Releases page for all available platforms and architectures.",
  },
];
---

<PageLayout
  lang={lang}
  title="Install"
  description="Install NAEOS — Go install, Docker, build from source, or download a pre-built binary."
>
  <div slot="header">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
      <span class="gradient-text">Install NAEOS</span>
    </h1>
    <p class="text-lg text-[#888] mb-4 max-w-2xl">
      Choose your preferred installation method. All methods provide the same <code class="text-[#00ff88]">naeos</code> CLI with full functionality.
    </p>
    <div class="flex flex-wrap gap-3 mb-12">
      <span class="text-xs font-mono text-[#666] px-3 py-1.5 rounded-full border border-[#333] bg-[#1a1a1a]">Go 1.25+</span>
      <span class="text-xs font-mono text-[#666] px-3 py-1.5 rounded-full border border-[#333] bg-[#1a1a1a]">Linux / macOS / Windows</span>
      <span class="text-xs font-mono text-[#666] px-3 py-1.5 rounded-full border border-[#333] bg-[#1a1a1a]">amd64 / arm64</span>
    </div>
  </div>

  <div class="container-main max-w-4xl mx-auto px-6">
    {methods.map(m => (
      <div class="glass p-8 mb-8">
        <div class="flex items-center gap-3 mb-2">
          <span class="text-2xl">{m.icon}</span>
          <h2 class="text-2xl font-bold">{m.title}</h2>
        </div>
        <p class="text-sm text-[#888] mb-6">{m.desc}</p>

        <div class="space-y-4">
          {m.steps.map((s, i) => (
            <div>
              <span class="text-xs text-[#666] font-medium mb-1 block">{s.label}</span>
              <div class="bg-[#0a0a0a] rounded-lg px-4 py-3 overflow-x-auto">
                <pre class="text-sm font-mono text-[#e0e0e0] whitespace-pre"><span class="text-[#00ff88]">$</span> {s.code}</pre>
              </div>
            </div>
          ))}
        </div>

        {m.note && (
          <p class="text-xs text-[#666] mt-4 flex items-start gap-2">
            <span class="text-[#ffaa00] shrink-0">ℹ</span>
            {m.note}
          </p>
        )}
      </div>
    ))}

    <div class="glass p-6 text-center">
      <p class="text-sm text-[#888] mb-4">After installation, create your first project:</p>
      <div class="bg-[#0a0a0a] rounded-lg p-4 inline-block text-left max-w-xl mx-auto">
        <pre class="text-sm font-mono"><span class="text-[#00ff88]">$</span> <span class="text-[#e0e0e0]">naeos init</span>
<span class="text-[#00ff88]">$</span> <span class="text-[#e0e0e0]">naeos scaffold --name my-project --language go</span>
<span class="text-[#00ff88]">$</span> <span class="text-[#e0e0e0]">cd my-project && naeos run --config config.yaml --input-file spec.yaml</span></pre>
      </div>
    </div>
  </div>
</PageLayout>
