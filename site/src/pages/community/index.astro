---
import PageLayout from "../../layouts/PageLayout.astro";

const lang = "en";

const channels = [
  {
    name: "GitHub Discussions",
    icon: "💬",
    desc: "Ask questions, share ideas, and discuss features with the community.",
    href: "https://github.com/NAEOS-foundation/naeos/discussions",
    cta: "Join Discussions",
  },
  {
    name: "Issue Tracker",
    icon: "🐛",
    desc: "Report bugs, request features, or track development progress.",
    href: "https://github.com/NAEOS-foundation/naeos/issues",
    cta: "Open Issues",
  },
  {
    name: "Contributing Guide",
    icon: "📝",
    desc: "Learn how to contribute code, documentation, or specifications.",
    href: "https://github.com/NAEOS-foundation/naeos/blob/main/CONTRIBUTING.md",
    cta: "Read Guide",
  },
  {
    name: "GitHub Sponsors",
    icon: "❤️",
    desc: "Support the project financially and help sustain development.",
    href: "https://github.com/sponsors/NAEOS-foundation",
    cta: "Sponsor",
  },
  {
    name: "Security Advisories",
    icon: "🛡️",
    desc: "Report security vulnerabilities responsibly.",
    href: "https://github.com/NAEOS-foundation/naeos/security/advisories",
    cta: "Report",
  },
  {
    name: "Code of Conduct",
    icon: "🤝",
    desc: "Our community standards and expectations for all participants.",
    href: "https://github.com/NAEOS-foundation/naeos/blob/main/CODE_OF_CONDUCT.md",
    cta: "Read",
  },
];

const stats = [
  { label: "Commits", value: "2000+" },
  { label: "Contributors", value: "10+" },
  { label: "Specifications", value: "56" },
  { label: "CLI Commands", value: "35+" },
  { label: "Languages", value: "5" },
  { label: "AI Adapters", value: "6" },
];
---

<PageLayout
  lang={lang}
  title="Community"
  description="Join the NAEOS community — contribute, discuss, report issues, and help shape the future of specification-driven engineering."
>
  <div slot="header">
    <h1 class="text-4xl md:text-5xl font-extrabold mb-4">
      <span class="gradient-text">Community</span>
    </h1>
    <p class="text-lg text-[#888] mb-12 max-w-2xl">
      Join the NAEOS community. All project discussions, development, and support happen on GitHub.
    </p>
  </div>

  <div class="container-main max-w-5xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-16">
      {channels.map(c => (
        <a href={c.href} target="_blank" rel="noopener noreferrer" class="glass p-6 hover:border-[#00ff88]/30 transition-all duration-300 group">
          <span class="text-3xl block mb-4">{c.icon}</span>
          <h2 class="text-lg font-bold mb-2 group-hover:text-[#00ff88] transition-colors">{c.name}</h2>
          <p class="text-sm text-[#888] mb-4 leading-relaxed">{c.desc}</p>
          <span class="text-xs text-[#00ff88] font-medium">{c.cta} →</span>
        </a>
      ))}
    </div>

    <div class="glass p-8 mb-12">
      <h2 class="text-xl font-bold mb-6 text-center">Project Stats</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6">
        {stats.map(s => (
          <div class="text-center">
            <div class="text-2xl font-bold text-[#00ff88] mb-1">{s.value}</div>
            <div class="text-xs text-[#666]">{s.label}</div>
          </div>
        ))}
      </div>
    </div>

    <div class="glass p-8 text-center">
      <h2 class="text-xl font-bold mb-4">How to Contribute</h2>
      <div class="max-w-2xl mx-auto text-left space-y-4 mb-8">
        {[
          { step: "1", title: "Read the Contributing Guide", desc: "Familiarize yourself with our conventions, PR process, and coding standards." },
          { step: "2", title: "Find an Issue", desc: "Look for issues labeled good-first-issue or help-wanted. Ask questions before starting." },
          { step: "3", title: "Fork & Branch", desc: "Fork the repo, create a feature branch, and make your changes." },
          { step: "4", title: "Submit a Pull Request", desc: "Open a PR with a clear description of what you changed and why." },
        ].map(item => (
          <div class="flex gap-4">
            <div class="w-8 h-8 rounded-full bg-[#00ff88] text-[#0a0a0a] text-sm font-bold flex items-center justify-center shrink-0">{item.step}</div>
            <div>
              <h3 class="font-semibold text-sm">{item.title}</h3>
              <p class="text-xs text-[#888]">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
      <a href="https://github.com/NAEOS-foundation/naeos/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[#00ff88] text-[#0a0a0a] font-semibold hover:bg-[#00cc6a] transition-colors">
        Read Contributing Guide ↗
      </a>
    </div>
  </div>
</PageLayout>
