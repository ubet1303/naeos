---
import "../styles.css";
import type { Lang } from "../i18n/utils";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

export interface Props {
  title: string;
  description: string;
  lang?: Lang;
  ogImage?: string;
}

const { title, description, lang = "en", ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const pageTitle = `${title} | NAEOS`;
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const isID = lang === "id";
const home = isID ? `${base}/id/` : `${base}/`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImage ?? `${base}/og-image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body class="min-h-screen">
    <Header lang={lang} currentPath={Astro.url.pathname} />
    <main class="pt-24 pb-16">
      <div class="container-main max-w-4xl mx-auto">
        <a href={home} class="inline-flex items-center gap-1 text-sm text-[#888] hover:text-[#00ff88] transition-colors mb-8">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          {isID ? "Kembali" : "Back"}
        </a>
        <slot name="header" />
      </div>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
