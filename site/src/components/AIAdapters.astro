---
import type { Lang } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const adapters = [
  { nameKey: "ai.copilot", color: "#00ADD8" },
  { nameKey: "ai.claude", color: "#D97706" },
  { nameKey: "ai.cursor", color: "#7C3AED" },
  { nameKey: "ai.gemini", color: "#4285F4" },
  { nameKey: "ai.codex", color: "#00B4D8" },
  { nameKey: "ai.opencode", color: "#00ff88" },
];
---

<section class="py-24 border-t border-[#333]">
  <div class="container-main">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{t("ai.title")}</h2>
      <p class="text-[#888] text-lg max-w-2xl mx-auto">{t("ai.subtitle")}</p>
    </div>

    <div class="flex flex-wrap items-center justify-center gap-4">
      {adapters.map((a) => (
        <div
          class="glass px-6 py-4 flex items-center gap-3 hover:scale-105 transition-transform duration-200 cursor-default"
        >
          <div class="w-3 h-3 rounded-full" style={{ background: a.color }} />
          <span class="text-sm font-medium text-[#e0e0e0]">{t(a.nameKey)}</span>
        </div>
      ))}
    </div>

    <div class="mt-12 max-w-2xl mx-auto glass p-6">
      <p class="text-sm text-[#888] text-center leading-relaxed">
        Compile NEIR models into AI instruction sets for 6 target tools — one spec, every AI assistant configured.
      </p>
    </div>
  </div>
</section>
