---
import type { Lang } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
---

<footer class="border-t border-[#333] bg-[#0a0a0a]">
  <div class="container-main py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="md:col-span-1">
        <div class="flex items-center gap-2 mb-4">
          <img src={`${base}/favicon.svg`} alt="NAEOS" class="w-7 h-7" />
          <span class="text-lg font-bold">NAEOS</span>
        </div>
        <p class="text-sm text-[#888] leading-relaxed mb-4">
          {t("footer.tagline")}
        </p>
        <p class="text-xs text-[#666]">
          &copy; {new Date().getFullYear()} {t("footer.foundation")}
        </p>
        <p class="text-xs text-[#666] mt-1">
          {t("footer.license")}
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-[#e0e0e0] mb-4">{t("footer.resources")}</h4>
        <ul class="space-y-3">
          <li>
            <a href="https://github.com/NAEOS-foundation/naeos/tree/main/docs" target="_blank" rel="noopener noreferrer" class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">
              {t("footer.docs")} ↗
            </a>
          </li>
          <li>
            <a href="https://github.com/NAEOS-foundation/naeos/tree/main/wiki" target="_blank" rel="noopener noreferrer" class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">
              {t("footer.wiki")} ↗
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-[#e0e0e0] mb-4">{t("footer.community")}</h4>
        <ul class="space-y-3">
          <li>
            <a href="https://github.com/NAEOS-foundation/naeos" target="_blank" rel="noopener noreferrer" class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">
              {t("footer.github")} ↗
            </a>
          </li>
          <li>
            <a href="https://github.com/NAEOS-foundation/naeos/blob/main/CONTRIBUTING.md" target="_blank" rel="noopener noreferrer" class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">
              {t("footer.contribute")} ↗
            </a>
          </li>
          <li>
            <a href="https://github.com/NAEOS-foundation/naeos/issues" target="_blank" rel="noopener noreferrer" class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">
              {t("footer.feedback")} ↗
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-[#e0e0e0] mb-4">{t("nav.docs")}</h4>
        <ul class="space-y-3">
          <li>
            <a href="https://github.com/NAEOS-foundation/naeos/blob/main/GETTING-STARTED.md" target="_blank" rel="noopener noreferrer" class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">
              Getting Started ↗
            </a>
          </li>
          <li>
            <a href="https://github.com/NAEOS-foundation/naeos/blob/main/CHANGELOG.md" target="_blank" rel="noopener noreferrer" class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">
              Changelog ↗
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-[#333] text-center">
      <p class="text-xs text-[#666]">
        {t("footer.tagline")}
      </p>
    </div>
  </div>
</footer>
