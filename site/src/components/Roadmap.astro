---
import type { Lang } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const milestones = [
  { version: "v0.1.0", label: "Foundation", done: true },
  { version: "v0.2.0", label: "Compiler", done: true },
  { version: "v0.3.0", label: "Core Spec", done: true },
  { version: "v0.4.0", label: "MCP + Marketplace", done: true },
  { version: "v1.0.0", label: "Stable Release", done: true },
  { version: "v1.5.0", label: "Production", done: true },
  { version: "v2.0.0", label: "Dashboard + Distributed", done: false },
];
---

<section id="roadmap" class="py-24 border-t border-[#333]">
  <div class="container-main">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{t("roadmap.title")}</h2>
      <p class="text-[#888] text-lg max-w-2xl mx-auto">{t("roadmap.subtitle")}</p>
    </div>

    <div class="max-w-4xl mx-auto">
      <div class="relative">
        <div class="absolute left-6 top-0 bottom-0 w-px bg-[#333]" />

        <div class="space-y-8">
          {milestones.map((m) => (
            <div class="relative flex gap-6 pl-0">
              <div class="relative z-10 flex items-center justify-center">
                <div
                  class={`w-12 h-12 rounded-full border-2 flex items-center justify-center text-sm font-bold shrink-0 ${
                    m.done
                      ? "bg-[#00ff88] border-[#00ff88] text-[#0a0a0a]"
                      : "bg-[#1a1a1a] border-[#00ff88] text-[#00ff88] animate-pulse"
                  }`}
                >
                  {m.done ? "✓" : m.version}
                </div>
              </div>
              <div class="flex-1 glass p-5">
                <div class="flex items-center gap-3 mb-1">
                  <span class={`text-xs font-bold font-mono ${m.done ? "text-[#00ff88]" : "text-[#666]"}`}>
                    {m.version}
                  </span>
                  {!m.done && (
                    <span class="text-[10px] font-medium text-[#ffaa00] px-2 py-0.5 rounded-full bg-[#ffaa0015]">
                      In Progress
                    </span>
                  )}
                </div>
                <span class="text-sm text-[#e0e0e0]">{m.label}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
