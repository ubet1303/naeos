---
import type { Lang } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";

export interface Props {
  lang: Lang;
  currentPath: string;
}

const { lang, currentPath } = Astro.props;
const t = useTranslations(lang);
const isID = lang === "id";
const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const home = isID ? `${base}/id/` : `${base}/`;
const install = isID ? `${base}/id/install/` : `${base}/install/`;
const docs = isID ? `${base}/id/docs/` : `${base}/docs/`;
const api = isID ? `${base}/id/api/` : `${base}/api/`;
const community = isID ? `${base}/id/community/` : `${base}/community/`;
const otherLang = isID ? "en" : "id";
const otherHref = isID ? base || "/" : `${base}/id/`;
---

<header class="fixed top-0 left-0 right-0 z-50 bg-[#0a0a0a]/80 backdrop-blur-md border-b border-[#333]">
  <div class="container-main flex items-center justify-between h-16">
    <a href={home} class="flex items-center gap-2 group">
      <img src={`${base}/favicon.svg`} alt="NAEOS" class="w-8 h-8" />
      <span class="text-xl font-bold text-[#e0e0e0] group-hover:text-[#00ff88] transition-colors">NAEOS</span>
    </a>

    <nav class="hidden lg:flex items-center gap-5">
      <a href={home} class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">{t("nav.home")}</a>
      <a href={install} class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">{isID ? "Instal" : "Install"}</a>
      <a href={docs} class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">{t("nav.docs")}</a>
      <a href={api} class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">API</a>
      <a href={community} class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">{isID ? "Komunitas" : "Community"}</a>
      <a href="https://github.com/NAEOS-foundation/naeos" target="_blank" rel="noopener noreferrer" class="text-sm text-[#888] hover:text-[#00ff88] transition-colors">
        {t("nav.github")} ↗
      </a>
    </nav>

    <div class="flex items-center gap-3">
      <a href={otherHref} class="text-xs font-medium px-3 py-1.5 rounded-full border border-[#333] text-[#888] hover:text-[#00ff88] hover:border-[#00ff88] transition-colors">
        {isID ? "EN" : "ID"}
      </a>
    </div>
  </div>
</header>
