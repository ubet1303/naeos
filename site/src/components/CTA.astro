---
import type { Lang } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-24 border-t border-[#333]">
  <div class="container-main">
    <div class="max-w-3xl mx-auto text-center glass p-12 md:p-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{t("cta.title")}</h2>
      <p class="text-[#888] text-lg mb-10 max-w-xl mx-auto">{t("cta.subtitle")}</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://github.com/NAEOS-foundation/naeos#quick-start"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-[#00ff88] text-[#0a0a0a] font-semibold hover:bg-[#00cc6a] transition-all duration-200"
        >
          {t("cta.getStarted")}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a
          href="https://github.com/NAEOS-foundation/naeos/tree/main/docs"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border border-[#333] text-[#e0e0e0] hover:border-[#00ff88] hover:text-[#00ff88] transition-all duration-200"
        >
          {t("cta.readDocs")} ↗
        </a>
      </div>
    </div>
  </div>
</section>
