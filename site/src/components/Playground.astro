---
const lang = "en";
const example = `project: my-app
modules:
  - name: auth
    path: ./internal/auth
  - name: api
    path: ./internal/api
    dependencies: [auth]
services:
  - name: gateway
    kind: http
    port: 8080
architecture:
  pattern: hexagonal
generation:
  languages: [go, typescript]`;
---

<div class="glass overflow-hidden" id="playground">
  <div class="border-b border-[#333] px-4 py-3 flex items-center justify-between bg-[#111]">
    <div class="flex items-center gap-3">
      <span class="text-sm font-semibold">Playground</span>
      <span class="text-[10px] text-[#666]">Try NAEOS in your browser</span>
    </div>
    <button
      id="run-playground"
      class="text-xs font-medium px-4 py-1.5 rounded-lg bg-[#00ff88] text-[#0a0a0a] hover:bg-[#00cc6a] transition-colors"
    >
      Run Pipeline ▶
    </button>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2">
    <div class="border-r border-[#333]">
      <div class="flex items-center gap-2 px-4 py-2 bg-[#1a1a1a] border-b border-[#333]">
        <span class="text-xs text-[#666] font-mono">spec.yaml</span>
      </div>
      <textarea
        id="playground-input"
        class="w-full h-80 bg-[#0a0a0a] text-sm font-mono text-[#e0e0e0] border-none resize-none p-4 focus:outline-none"
        spellcheck="false"
      >{example}</textarea>
    </div>

    <div>
      <div class="flex items-center gap-2 px-4 py-2 bg-[#1a1a1a] border-b border-[#333]">
        <span class="text-xs text-[#666] font-mono">Output</span>
        <span id="playground-status" class="text-[10px] text-[#666]">ready</span>
      </div>
      <pre id="playground-output" class="w-full h-80 bg-[#0a0a0a] text-sm font-mono text-[#888] p-4 overflow-auto m-0 whitespace-pre-wrap">Click "Run Pipeline" to process this specification...</pre>
    </div>
  </div>
</div>

<script>
  const input = document.getElementById("playground-input");
  const output = document.getElementById("playground-output");
  const status = document.getElementById("playground-status");
  const runBtn = document.getElementById("run-playground");

  runBtn?.addEventListener("click", async () => {
    const spec = input?.value || "";
    runBtn.disabled = true;
    runBtn.textContent = "Processing...";
    status.textContent = "running";
    output.textContent = "";

    // Simulate pipeline stages with realistic timing
    const stages = [
      { name: "Parse", duration: 200 },
      { name: "Normalize", duration: 150 },
      { name: "Resolve", duration: 250 },
      { name: "Build NEIR", duration: 300 },
      { name: "Validate", duration: 200 },
      { name: "Schedule", duration: 150 },
      { name: "Generate", duration: 400 },
      { name: "Render", duration: 250 },
      { name: "Review", duration: 200 },
    ];

    const lines = spec.split("\n").filter(l => l.trim());
    const modules = lines.filter(l => l.trim().startsWith("- name:")).length;
    const services = lines.filter(l => l.trim().startsWith("kind:")).length;
    const langs = lines.filter(l => l.includes("languages:")).length > 0
      ? lines.find(l => l.includes("languages:"))?.match(/\[(.*?)\]/)?.[1]?.split(",").map(s => s.trim()) || []
      : [];

    let out = "";

    for (const stage of stages) {
      out += `[${stage.name.padEnd(12)}] ✓ completed (${stage.duration}ms)\n`;
      output.textContent = out;
      await new Promise(r => setTimeout(r, stage.duration));
    }

    const total = stages.reduce((s, st) => s + st.duration, 0);
    out += `\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n`;
    out += ` Pipeline Complete\n`;
    out += `━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n`;
    out += ` Project:     ${spec.match(/project:\s*(.+)/)?.[1] || "unknown"}\n`;
    out += ` Modules:     ${modules}\n`;
    out += ` Services:    ${services}\n`;
    out += ` Languages:   ${langs.join(", ") || "none specified"}\n`;
    out += ` Status:      valid ✓\n`;
    out += ` Duration:    ${total}ms\n`;
    out += ` Artifacts:   ${modules + services + 5}\n`;
    out += `━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n`;

    output.textContent = out;
    status.textContent = "completed ✓";
    runBtn.disabled = false;
    runBtn.textContent = "Run Pipeline ▶";
  });
</script>
