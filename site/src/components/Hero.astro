---
import type { Lang } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative min-h-[90vh] flex items-center pt-16 overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,_#00ff8808_0%,_transparent_60%)] pointer-events-none" />

  <div class="container-main relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-[#333] bg-[#1a1a1a] mb-8">
        <span class="w-2 h-2 rounded-full bg-[#00ff88] animate-pulse" />
        <span class="text-xs text-[#888]">v2.1.0 &middot; Open Source &middot; Apache 2.0</span>
      </div>

      <h1 class="text-5xl md:text-7xl font-extrabold leading-tight mb-6">
        <span class="gradient-text">{t("hero.tagline")}</span>
      </h1>

      <p class="text-lg md:text-xl text-[#888] leading-relaxed max-w-2xl mx-auto mb-10">
        {t("hero.subtitle")}
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="https://github.com/NAEOS-foundation/naeos#quick-start"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-[#00ff88] text-[#0a0a0a] font-semibold hover:bg-[#00cc6a] transition-all duration-200"
        >
          {t("hero.cta")}
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a
          href="https://github.com/NAEOS-foundation/naeos"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl border border-[#333] text-[#e0e0e0] hover:border-[#00ff88] hover:text-[#00ff88] transition-all duration-200"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          {t("hero.viewGithub")}
        </a>
      </div>

      <div class="mt-16 glass p-6 text-left">
        <div class="flex items-center gap-2 mb-3">
          <span class="text-xs text-[#00ff88] font-mono">$</span>
          <span class="text-xs text-[#888] font-mono">{t("quickstart.code.example")}</span>
        </div>
        <pre class="text-sm font-mono text-[#e0e0e0] leading-relaxed"><span class="text-[#66b3ff]">project</span>: my-app
<span class="text-[#66b3ff]">modules</span>:
  - <span class="text-[#66b3ff]">name</span>: auth
  - <span class="text-[#66b3ff]">name</span>: api
    <span class="text-[#66b3ff]">dependencies</span>: [auth]
<span class="text-[#66b3ff]">services</span>:
  - <span class="text-[#66b3ff]">name</span>: gateway
    <span class="text-[#66b3ff]">kind</span>: http
    <span class="text-[#66b3ff]">port</span>: 8080
<span class="text-[#66b3ff]">architecture</span>:
  <span class="text-[#66b3ff]">pattern</span>: hexagonal
<span class="text-[#66b3ff]">generation</span>:
  <span class="text-[#66b3ff]">languages</span>: [go, typescript]</pre>
        <div class="flex items-center gap-2 mt-3 pt-3 border-t border-[#333]">
          <span class="text-xs text-[#00ff88] font-mono">$</span>
          <span class="text-xs text-[#e0e0e0] font-mono">{t("quickstart.code.run")}</span>
        </div>
      </div>
    </div>
  </div>
</section>
