---
export interface Props {
  icon: string;
  title: string;
  description: string;
  details: string[];
  code?: string;
  codeLang?: string;
}
const { icon, title, description, details, code, codeLang } = Astro.props;
---

<div class="glass p-8 mb-8">
  <div class="flex items-start gap-4 mb-4">
    <span class="text-3xl shrink-0">{icon}</span>
    <div>
      <h2 class="text-2xl font-bold mb-2">{title}</h2>
      <p class="text-[#888] leading-relaxed">{description}</p>
    </div>
  </div>

  <ul class="space-y-2 mb-6 ml-12">
    {details.map(d => (
      <li class="flex items-start gap-2 text-sm text-[#e0e0e0]">
        <span class="text-[#00ff88] mt-0.5">▸</span>
        <span>{d}</span>
      </li>
    ))}
  </ul>

  {code && (
    <div class="bg-[#0a0a0a] rounded-lg p-4 overflow-x-auto ml-12">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xs text-[#666] font-mono uppercase tracking-wider">{codeLang || "yaml"}</span>
      </div>
      <pre class="text-sm font-mono text-[#e0e0e0] leading-relaxed whitespace-pre">{code}</pre>
    </div>
  )}
</div>
