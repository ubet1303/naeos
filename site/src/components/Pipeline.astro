---
import type { Lang } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const stages = [
  "pipeline.parse",
  "pipeline.normalize",
  "pipeline.resolve",
  "pipeline.build",
  "pipeline.validate",
  "pipeline.schedule",
  "pipeline.generate",
  "pipeline.render",
  "pipeline.review",
] as const;
---

<section class="py-24 border-t border-[#333]">
  <div class="container-main">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{t("pipeline.title")}</h2>
      <p class="text-[#888] text-lg max-w-2xl mx-auto">{t("pipeline.subtitle")}</p>
    </div>

    <div class="relative">
      <div class="hidden lg:block absolute top-12 left-0 right-0 h-0.5 bg-gradient-to-r from-[#00ff88]/20 via-[#00ff88] to-[#00ff88]/20" />

      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-9 gap-4">
        {stages.map((stage, i) => (
          <div class="relative flex flex-col items-center text-center group">
            <div class="w-10 h-10 rounded-full bg-[#1a1a1a] border border-[#333] flex items-center justify-center text-xs font-bold text-[#00ff88] mb-3 group-hover:bg-[#00ff88] group-hover:text-[#0a0a0a] transition-all duration-300 z-10">
              {i + 1}
            </div>
            <span class="text-xs text-[#888] font-medium group-hover:text-[#00ff88] transition-colors">
              {t(stage)}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
