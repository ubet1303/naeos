---
import type { Lang } from "../i18n/utils";
import { useTranslations } from "../i18n/utils";

export interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const steps = [
  {
    cmd: "git clone https://github.com/NAEOS-foundation/naeos.git",
    label: "Clone",
  },
  {
    cmd: "cd naeos && go build ./cmd/naeos/",
    label: "Build",
  },
  {
    cmd: `cat > spec.yaml << 'EOF'\nproject: my-app\nmodules:\n  - name: auth\nservices:\n  - name: gateway\n    kind: http\n    port: 8080\nEOF`,
    label: "Create Spec",
  },
  {
    cmd: "naeos run --config config.yaml --input-file spec.yaml",
    label: "Run",
  },
];
---

<section class="py-24 border-t border-[#333]">
  <div class="container-main">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">{t("quickstart.title")}</h2>
      <p class="text-[#888] text-lg max-w-2xl mx-auto">{t("quickstart.subtitle")}</p>
    </div>

    <div class="max-w-3xl mx-auto">
      {steps.map((step, i) => (
        <div class="flex gap-4 mb-4 last:mb-0">
          <div class="flex flex-col items-center">
            <div class="w-8 h-8 rounded-full bg-[#00ff88] text-[#0a0a0a] text-xs font-bold flex items-center justify-center shrink-0">
              {i + 1}
            </div>
            {i < steps.length - 1 && <div class="w-px flex-1 bg-[#333] my-1" />}
          </div>
          <div class="flex-1 glass p-4 overflow-x-auto">
            <div class="flex items-center gap-2 mb-1">
              <span class="text-xs text-[#666] font-medium">{step.label}</span>
            </div>
            <pre class="text-sm font-mono text-[#e0e0e0]"><span class="text-[#00ff88]">$</span> {step.cmd}</pre>
          </div>
        </div>
      ))}

      <p class="text-center text-sm text-[#888] mt-8">{t("quickstart.desc")}</p>
    </div>
  </div>
</section>
